# Local development environment for the NECTAR platform.
# Copy to .env (gitignored) and fill in values. KEY=value syntax (not "key: value").
# Loaded for local runs by `python -m nutriscrape ...` and `make flow` via
# common.config.load_env_file, which walks up from the working directory to find this file.
# An already-exported shell variable always wins over the file, and containers inject the
# environment directly (quadlet / --env-file), so this file is a no-op there.
#
# In the container deployment, secrets (passwords, API keys) go in `podman secret`, never a file;
# see deploy/env/platform.env.example and deploy/README.md.

# ---- USDA FoodData Central ----
# The code reads FDC_API_KEY. Only a fallback when FDC_BULK_DIR is not imported; the bulk CSV
# export (below) needs no key and is not rate-limited. Get a free key at https://api.data.gov/signup
FDC_API_KEY=

# ---- Neo4j (batch writer role) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
# NEO4J_DATABASE=neo4j

# ---- Batch data engine (NutriScrape) ----
CONTRACT_VERSION=1.0
# Parallel ingest batches for the flow (make flow / python -m nutriscrape flow).
NUTRISCRAPE_MAX_PARALLEL=4

# Recipe corpus: a RecipeNLG-style CSV, or a .txt/.urls list of schema.org recipe URLs. Leave unset
# to use the bundled 7-recipe sample. Point it at the full RecipeNLG export (~2.2 GB, non-commercial
# research/educational license) from https://recipenlg.cs.put.poznan.pl (or HF mirror mbien/recipe_nlg):
# NUTRISCRAPE_CORPUS=/data/recipes_full.csv

# USDA FDC CSV bulk export directory (food.csv, nutrient.csv, food_nutrient.csv). When set,
# `fdc-import` loads it and ingest resolves foods locally with no FDC API call (preferred at scale).
# Download from https://fdc.nal.usda.gov/download-datasets
# FDC_BULK_DIR=/fdc
