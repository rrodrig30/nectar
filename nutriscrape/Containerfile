# NutriScrape batch image. Build from the repo root:
#   podman build -t localhost/nutriscrape:latest -f nutriscrape/Containerfile .
FROM docker.io/library/python:3.11-slim AS build
ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
WORKDIR /app
# shared contract package first, then the program. src and config are copied before `pip install .`
# because the package is a src-layout project ([tool.setuptools.packages.find] where=["src"]), so the
# sources must be present for the build to discover the `nutriscrape` package.
COPY contract/nectar_contract ./nectar_contract
# The contract DDL is a data file (not part of the wheel); stage it at /app/contract/schema so
# graph/schema.find_schema_path finds it via the working-directory fallback at runtime.
COPY contract/schema ./contract/schema
COPY nutriscrape/pyproject.toml ./
COPY nutriscrape/src ./src
COPY nutriscrape/config ./config
# The disease-rule condition YAMLs are authored under nectar/config/conditions (root map), but
# NutriScrape is the writer that persists them to the graph. Stage them at /app/config/conditions so
# `run_knowledge` finds them via the config/conditions branch and loads the clinical rule KB.
COPY nectar/config/conditions ./config/conditions
RUN pip install --upgrade pip && pip install .

FROM docker.io/library/python:3.11-slim
ENV PYTHONUNBUFFERED=1
WORKDIR /app
COPY --from=build /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=build /app /app
# entrypoint dispatches a stage: ingest | cluster | knowledge | materialize | run-all
ENTRYPOINT ["python", "-m", "nutriscrape"]
CMD ["run-all"]
